# ─── Configurações gerais ──────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=False

# ─── Hosts permitidos ─────────────────────────────────────────────────────────
# Coloque o domínio do Render (ex: auracash-backend.onrender.com)
ALLOWED_HOSTS=auracash-backend.onrender.com,localhost

# ─── Banco de dados ───────────────────────────────────────────────────────────
# O Render preenche DATABASE_URL automaticamente.
# Para desenvolvimento local, use as variáveis individuais abaixo:
# DATABASE_URL=postgresql://auracash:auracash123@localhost:5432/auracash
DB_NAME=auracash
DB_USER=auracash
DB_PASSWORD=auracash123
DB_HOST=localhost
DB_PORT=5432

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
# URL do Vercel após o deploy (ex: https://auracash.vercel.app)
FRONTEND_URL=http://localhost:5173

# ─── Redis / Celery (opcional) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
